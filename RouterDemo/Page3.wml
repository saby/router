<div class="my-little-grid">

   <div class="left-menu">
      <h1>Left menu</h1>
      <ws:for data="i in dataMenu">
         <Router.Link scope="{{i.scopeLink}}">
            <a>{{i.title}}</a>
         </Router.Link>
      </ws:for>
   </div>

   <div class="content">
      <h2>Content will be here</h2>
   </div>
</div>
