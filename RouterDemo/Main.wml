<div>
   <nav class="TopMenu__container">
      <ul class="TopMenu">
         <li class="TopMenu__Item">
            <Router.router:Reference state="/page/:pageId" pageId="Intro" attr:class="TopMenu__Link">
               <a href="{{ content.href }}">Intro</a>
            </Router.router:Reference>
         </li>
         <li class="TopMenu__Item">
            <Router.router:Reference state="/page/:pageId" pageId="SPRouting" attr:class="TopMenu__Link">
               <a href="{{ content.href }}">SPA Routing</a>
            </Router.router:Reference>
         </li>
         <li class="TopMenu__Item">
            <Router.router:Reference state="/:docId" docId="123456" attr:class="TopMenu__Link">
               <a href="{{ content.href }}">RegExp In Root</a>
            </Router.router:Reference>
         </li>
      </ul>
   </nav>
   <main class="ContentContainer">
      <Router.router:Route mask="/page/:pageId">
         <div>
            <ws:if data="{{ content.pageId }}">
               <RouterDemo.resources.PageLoader />
            </ws:if>
         </div>
      </Router.router:Route>

      <Router.router:Route mask="/doc/:docId">
         <div>
            <ws:if data="{{ content.docId }}">
               <h1>Демонстрация регулярного выражения в router.json</h1>
               <p>
                  ...<br/>
                  "/regex:^([0-9]{6})$": "RouterDemo/$1"<br/>
                  ...
               </p>
            </ws:if>
         </div>
      </Router.router:Route>
   </main>
</div>
