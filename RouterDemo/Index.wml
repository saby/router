<UI.Base:HTML
        attr:application="RouterDemo/Index"
        attr:rootapp="UI/Base:Document"
        scope="{{_options}}">
    <ws:bodyTemplate>
        <ws:partial template="{{bodyTemplate.content}}">
            <ws:bodyContent>
                <RouterDemo.Main />
            </ws:bodyContent>
        </ws:partial>
    </ws:bodyTemplate>
</UI.Base:HTML>
