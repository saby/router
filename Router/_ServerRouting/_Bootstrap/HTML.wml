<!DOCTYPE html>
<html lang="en">
<head>
    {{ __setHTMLUnsafe(HeadAPIData) }}
</head>
  <body class="{{ BodyAPIClasses }}">
    <div id="wasaby-content" style="width: inherit; height: inherit;" application="{{ moduleName }}">
      {{ __setHTMLUnsafe(controlsHTML) }}
    </div>

    <div class="wasabyBaseDeps">
      {{ __setHTMLUnsafe(JSLinksAPIBaseData) }}
    </div>
    <div class="wasabyUtilScripts">
      {{ __setHTMLUnsafe(JSLinksAPIUtilScriptsData) }}
    </div>
    <div class="wasabyJSDeps">
      {{ __setHTMLUnsafe(JSLinksAPIData) }}
    </div>
    <div id="wasabyStartScript">
      <Router._ServerRouting._Bootstrap.StartApplicationScript requiredModules="{{ requiredModules }}" onServer="{{ true }}"/>
    </div>
  </body>
</html>
